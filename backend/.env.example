APP_NAME=Capybara Coach API
ENVIRONMENT=development
DATABASE_URL=sqlite:///./capybara_coach.db
# Railway example:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@HOST:PORT/capybara_coach
STORAGE_DIR=./storage

DEMO_USER_ID=demo-user
DEMO_USER_EMAIL=student@capybaracoach.local
DEMO_USER_NAME=Demo Student

STT_PROVIDER=auto
STT_BASE_URL=https://api.openai.com/v1
STT_API_KEY=
STT_MODEL=gpt-4o-mini-transcribe
STT_TIMEOUT_SECONDS=300

FASTER_WHISPER_MODEL=small
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE_TYPE=int8

LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=TODO_LLM_API_KEY
LLM_MODEL=TODO_LLM_MODEL
