APP_NAME=DictaCoach
APP_ENV=development
USE_FIREBASE=false
PIPELINE_MODE=fastapi
API_BASE_URL=TODO_RAILWAY_BACKEND_URL
API_POLL_INTERVAL_SECONDS=3
API_READY_TIMEOUT_SECONDS=90

DEMO_USER_ID=demo-user
DEMO_USER_EMAIL=student@dictacoach.local
DEMO_USER_NAME=Demo Student

TRANSCRIPTION_PROVIDER=faster-whisper
TRANSCRIPTION_API_KEY=TODO_TRANSCRIPTION_API_KEY

LLM_PROVIDER=backend
LLM_API_KEY=TODO_LLM_API_KEY

EMBEDDINGS_PROVIDER=mock
EMBEDDINGS_API_KEY=TODO_EMBEDDINGS_API_KEY

FIREBASE_API_KEY=TODO_FIREBASE_API_KEY
FIREBASE_AUTH_DOMAIN=TODO_FIREBASE_AUTH_DOMAIN
FIREBASE_PROJECT_ID=TODO_FIREBASE_PROJECT_ID
FIREBASE_STORAGE_BUCKET=TODO_FIREBASE_STORAGE_BUCKET
FIREBASE_MESSAGING_SENDER_ID=TODO_FIREBASE_MESSAGING_SENDER_ID
FIREBASE_ANDROID_APP_ID=TODO_FIREBASE_ANDROID_APP_ID
FIREBASE_IOS_APP_ID=TODO_FIREBASE_IOS_APP_ID
FIREBASE_WEB_APP_ID=TODO_FIREBASE_WEB_APP_ID

ANDROID_APPLICATION_ID=com.example.dictacoach
IOS_BUNDLE_ID=com.example.dictacoach
FUNCTIONS_REGION=us-central1
